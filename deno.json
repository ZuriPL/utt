{
	"name": "utt",
	"version": "0.1.0",
	"imports": {
		"$/": "./",
		"$types/": "./types/",
		"$src/": "./src/",
		"$public/": "./public/",
		"@deno/emit": "jsr:@deno/emit@^0.46.0",
		"@inquirer/prompts": "npm:@inquirer/prompts@^8.5.2",
		"@std/crypto": "jsr:@std/crypto@^1.1.0",
		"@std/encoding": "jsr:@std/encoding@^1.0.10",
		"@std/fmt": "jsr:@std/fmt@^1.0.10",
		"@std/fs": "jsr:@std/fs@^1.0.24",
		"@std/json": "jsr:@std/json@^1.1.0",
		"@std/path": "jsr:@std/path@^1.1.5",
		"@std/streams": "jsr:@std/streams@^1.1.1",
		"@std/tar": "jsr:@std/tar@^0.1.10",
		"@zip-js/zip-js": "jsr:@zip-js/zip-js@^2.8.26",
		"archiver": "npm:archiver@^8.0.0",
		"chalk": "npm:chalk@^5.6.2",
		"commander": "npm:commander@^15.0.0",
		"conf": "npm:conf@^15.1.0",
		"log-update": "npm:log-update@^8.0.0",
		"ora": "npm:ora@^9.4.0",
		"@types/node": "npm:@types/node@^25.9.1",
		"yoctocolors": "npm:yoctocolors@^2.1.2",
		"utt": "./shared/sdk.ts"
	},
	"compile": {
		"permissions": {
			"all": true
		}
	},
	"tasks": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"build": "deno compile -P --output dist/ut src/cli.ts",
		"install": "deno install --force --config deno.json --global --name utt --allow-all src/cli.ts"
	},
	"exports": "./shared/sdk.ts",
	"fmt": {
		"useTabs": true,
		"lineWidth": 100,
		"indentWidth": 4,
		"semiColons": false,
		"singleQuote": false,
		"proseWrap": "always",
		"exclude": [".utt"]
	}
}
